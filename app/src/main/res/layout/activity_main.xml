<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prepaid Meter Lookup"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BPDB — C&amp;D / S&amp;D Division Sunamganj"
            android:textColor="#BBDEFB"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Input card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:margin="12dp"
        android:padding="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meter Number (12 digits)"
            android:textColor="#37474F"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/meterInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter 12-digit prepaid meter number"
            android:inputType="number"
            android:maxLength="12"
            android:padding="12dp"
            android:textSize="16sp"
            android:background="@android:color/transparent"
            android:imeOptions="actionSearch" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <Button
            android:id="@+id/searchBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="SEARCH"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="#1565C0" />
    </LinearLayout>

    <!-- Result area — scrollable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />

    </ScrollView>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Developed by MD Jasim Uddin — Sub Assistant Engineer, BPDB"
        android:textColor="#90A4AE"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="8dp"
        android:background="#FFFFFF" />

</LinearLayout>
